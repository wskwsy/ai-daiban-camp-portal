   "sender_id": 265,
   "sender": "谢倩",
   "content": "![图片](http://127.0.0.1:5030/image/dc771483928839d59138a2fa3587861f,msg/attach/395e129f24f5bf00da88ea52e9acece5/2026-06/Img/d26fad31a52715cf0be8b6e011d4ccf4)",
