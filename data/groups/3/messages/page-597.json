  },
  {
   "id": 14854,
   "time": "2026-01-21 17:16",
   "date": "2026-01-21",
   "sender_id": 246,
   "sender": "菜籽油",
   "content": "远程二维码添加好友，会被系统认为你们有什么不当的事",
